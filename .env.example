# =============================================================================
# TradingAgents — LLM Provider Configuration
# Copy this file to .env, fill in your keys, and activate one config block.
#
# HOW TO SWITCH CONFIGS
# =====================
# Each "ACTIVE CONFIG" block below is a complete, self-contained profile.
# To switch:
#   1. Comment out ALL lines in the current active block (add # to each line)
#   2. Uncomment ALL lines in the block you want to activate (remove #)
#   3. Restart the engine / CLI — no other changes needed.
#
# The TRADINGAGENTS_LLM_BACKEND_URL line is only needed when routing through
# a gateway (e.g. Doubleword). For direct provider calls, leave it commented out.
# =============================================================================


# =============================================================================
# ACTIVE CONFIG 1 — Doubleword via Pydantic AI / Logfire Gateway
# -----------------------------------------------------------------------------
# Free hackathon credits. Routes all LLM calls through the Logfire gateway to
# Doubleword's open-weight inference cluster (DeepSeek V4 Flash / Pro).
# Provider stays "deepseek" so TradingAgents uses DeepSeekChatOpenAI which
# correctly handles chain-of-thought reasoning content in multi-turn calls.
#
# Setup:
#   1. Create a Logfire account at https://logfire.pydantic.dev
#   2. Redeem your hackathon promo code at https://pydantic.dev/hackathon
#   3. Go to Gateway → API Keys and create a key (starts with pylf_v2_)
#   4. Paste the key below and activate this block
#
# Rotate key: logfire.pydantic.dev → Gateway → API Keys → Regenerate
# Models:     https://docs.doubleword.ai/inference-api/models.md
# =============================================================================
#TRADINGAGENTS_LLM_PROVIDER=deepseek
#TRADINGAGENTS_LLM_BACKEND_URL=https://gateway-eu.pydantic.dev/proxy/doubleword
#DEEPSEEK_API_KEY=pylf_v2_eu_your-logfire-key-here
#TRADINGAGENTS_QUICK_THINK_LLM=deepseek-ai/DeepSeek-V4-Flash
#TRADINGAGENTS_DEEP_THINK_LLM=deepseek-ai/DeepSeek-V4-Pro


# =============================================================================
# ACTIVE CONFIG 2 — DeepSeek Direct API
# -----------------------------------------------------------------------------
# Standard DeepSeek API. Use if Doubleword credits run out or as a fallback.
#
# Key:    https://platform.deepseek.com → API Keys
# Models: deepseek-v4-flash (quick), deepseek-v4-pro (deep)
# =============================================================================
#TRADINGAGENTS_LLM_PROVIDER=deepseek
#TRADINGAGENTS_LLM_BACKEND_URL=   # leave blank = use DeepSeek default endpoint
#DEEPSEEK_API_KEY=sk-...
#TRADINGAGENTS_QUICK_THINK_LLM=deepseek-v4-flash
#TRADINGAGENTS_DEEP_THINK_LLM=deepseek-v4-pro


# =============================================================================
# ACTIVE CONFIG 3 — OpenAI (GPT-4o / GPT-5)
# -----------------------------------------------------------------------------
# Structured output uses the Responses API — only on native OpenAI endpoints,
# not via any gateway. Highest quality but most expensive.
#
# Key: https://platform.openai.com → API Keys
# =============================================================================
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_LLM_BACKEND_URL=   # leave blank = use OpenAI default endpoint
#OPENAI_API_KEY=sk-...
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-4.1-mini
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-4.1


# =============================================================================
# ACTIVE CONFIG 4 — Anthropic (Claude)
# -----------------------------------------------------------------------------
# Key: https://console.anthropic.com → API Keys
# =============================================================================
#TRADINGAGENTS_LLM_PROVIDER=anthropic
#TRADINGAGENTS_LLM_BACKEND_URL=   # leave blank = use Anthropic default endpoint
#ANTHROPIC_API_KEY=sk-ant-...
#TRADINGAGENTS_QUICK_THINK_LLM=claude-haiku-4-5-20251001
#TRADINGAGENTS_DEEP_THINK_LLM=claude-sonnet-4-6


# =============================================================================
# Other API keys — fill in if you have them (used by non-active configs)
# =============================================================================
#GOOGLE_API_KEY=
#XAI_API_KEY=
#DASHSCOPE_API_KEY=
#DASHSCOPE_CN_API_KEY=
#ZHIPU_API_KEY=
#OPENROUTER_API_KEY=


# =============================================================================
# TradingAgents runtime tuning (optional — uncomment to override defaults)
# =============================================================================
#TRADINGAGENTS_TEMPERATURE=0.0
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_BENCHMARK_TICKER=


# =============================================================================
# Competition Engine Settings
# =============================================================================

# Analysts to run (comma-separated). Options: market, social, news, fundamentals
# Default: market,social,news,fundamentals (all 4 for thorough analysis)
# Speed optimization: market,fundamentals (skip social/news to save time)
#COMPETITION_ANALYSTS=market,social,news,fundamentals

# Instruments to trade (comma-separated)
# Default: TEAM_A_INSTRUMENTS (Forex majors + XAUUSD = low volatility = high Sharpe)
# All instruments: COMPETITION_INSTRUMENTS=ALL in config.py adds crypto
# Examples:
#   - EURUSD,GBPUSD,USDJPY,XAUUSD (conservative Forex)
#   - EURUSD,GBPUSD,XAUUSD,BARUSD (Forex + HBAR)
#   - XAUUSD (gold only — good for testing)
#COMPETITION_INSTRUMENTS=XAUUSD

# Run mode (1 = dry-run, 0 = live orders). Default: 1 (safe, no real orders)
# During competition: set to 0 to execute real trades
#COMPETITION_DRY_RUN=1

# Skip LLM analysis, use indicator-only signals (RSI/MACD/Bollinger)
# Default: unset (run full LLM pipeline)
# Use "1" to speed up testing or when API credits are low
#COMPETITION_NO_LLM=1

# Log directory for engine/web/frontend output
# Default: .logs/ (in project root)
# Can set to ~/competition-logs or /var/log/competition etc
#LOG_DIR=.logs

# API port (default: 8000)
# Change if port 8000 is already in use on your machine
#TRADINGAGENTS_WEB_PORT=8000

# Frontend dev server port (default: 5173)
# Change if port 5173 is already in use
#VITE_PORT=5173
